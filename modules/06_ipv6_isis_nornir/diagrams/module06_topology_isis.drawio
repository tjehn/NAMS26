        <mxCell id="legend_text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#FFFFFF;fontSize=10;" value="&lt;font color=&quot;#FFD700&quot;&gt;━━&lt;/font&gt; Gold border — L2 backbone (BB-1, BB-2) or L1/L2 ABR&lt;br&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;━━&lt;/font&gt; White border — L1 leaf router (BR-1 through BR-5)&lt;br&gt;&lt;font color=&quot;#FF4444&quot;&gt;━━&lt;/font&gt; Red border — ASBR (IS-IS + OSPF boundary)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#4A90D9&quot;&gt;█&lt;/font&gt; Blue container — L2 backbone area (49.0001)&lt;br&gt;&lt;font color=&quot;#2bbbad&quot;&gt;█&lt;/font&gt; Teal container — L1 stub area (49.0002, 49.0003, 49.0004)&lt;br&gt;&lt;font color=&quot;#FF8C00&quot;&gt;█&lt;/font&gt; Orange dashed — OSPF stub domain&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;───&lt;/font&gt; Solid white — IS-IS adjacency&lt;br&gt;&lt;font color=&quot;#FF8C00&quot;&gt;- - -&lt;/font&gt; Orange dashed — OSPF adjacency&lt;br&gt;&lt;font color=&quot;#2bbbad&quot;&gt;━━━&lt;/font&gt; Teal bar — shared broadcast LAN (DIS election)" vertex="1">
